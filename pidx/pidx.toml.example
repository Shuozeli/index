[[categories]]
key = "database"
title = "Data & Database"

[[categories]]
key = "devtools"
title = "Developer Tools"

[[repos]]
name = "protobuf-rs"
category = "serialization"

[[repos]]
name = "pwright"
category = "devtools"

[[repos]]
name = "quiver-orm"
category = "database"
